generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  REVISOR_OCR
  SOLICITANTE
}

enum DocumentStatus {
  CARGADO
  PROCESANDO
  PROCESADO
  PENDIENTE_REVISION
  CONFIRMADO
  ERROR_OCR
}

model User {
  id             String            @id @default(uuid())
  name           String
  email          String            @unique
  passwordHash   String
  role           RoleName
  active         Boolean           @default(true)
  documents      Document[]
  confirmations  OCRConfirmation[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model Document {
  id            String            @id @default(uuid())
  fileName      String
  fileType      String
  mimeType      String
  storagePath   String
  sizeBytes     BigInt
  status        DocumentStatus    @default(CARGADO)
  userId        String
  user          User              @relation(fields: [userId], references: [id])
  ocrResult     OCRResult?
  confirmation  OCRConfirmation?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model OCRResult {
  id                   String                @id @default(uuid())
  documentId           String                @unique
  document             Document              @relation(fields: [documentId], references: [id])

  extractedText        String?
  averageConfidence    Decimal?              @db.Decimal(5, 2)
  processStatus        String
  errorMessage         String?

  countryDetected      String?
  languageDetected     String?
  documentTypeDetected String?

  currencyCode         String?
  currencySymbol       String?
  decimalSeparator     String?
  thousandsSeparator   String?

  subtotalAmount       Decimal?              @db.Decimal(14, 2)
  taxAmount            Decimal?              @db.Decimal(14, 2)
  totalAmount          Decimal?              @db.Decimal(14, 2)
  taxIncludedInPrices  Boolean?

  extractedFields      ExtractedField[]
  extraFields          ExtractedExtraField[]
  extractedLineItems   ExtractedLineItem[]

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model ExtractedField {
  id               String    @id @default(uuid())
  ocrResultId      String
  ocrResult        OCRResult @relation(fields: [ocrResultId], references: [id])

  fieldName        String
  rawLabel         String?
  detectedValue    String?
  normalizedValue  String?
  finalValue       String?
  confidence       Decimal?  @db.Decimal(5, 2)
  wasCorrected     Boolean   @default(false)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ExtractedExtraField {
  id            String    @id @default(uuid())
  ocrResultId   String
  ocrResult     OCRResult @relation(fields: [ocrResultId], references: [id])

  rawLabel      String?
  rawValue      String?
  confidence    Decimal?  @db.Decimal(5, 2)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ExtractedLineItem {
  id            String    @id @default(uuid())
  ocrResultId   String
  ocrResult     OCRResult @relation(fields: [ocrResultId], references: [id])

  lineNumber    Int
  article       String?
  description   String?
  quantity      Decimal?  @db.Decimal(12, 2)
  unitPrice     Decimal?  @db.Decimal(12, 2)
  lineSubtotal  Decimal?  @db.Decimal(12, 2)
  lineTax       Decimal?  @db.Decimal(12, 2)
  lineTotal     Decimal?  @db.Decimal(12, 2)
  taxIncluded   Boolean?
  confidence    Decimal?  @db.Decimal(5, 2)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model OCRConfirmation {
  id               String   @id @default(uuid())
  documentId       String   @unique
  document         Document @relation(fields: [documentId], references: [id])
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  observations     String?
  confirmationDate DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}